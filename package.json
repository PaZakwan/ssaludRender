{
  "name": "secretaria-de-salud-moreno",
  "version": "1.0.0",
  "description": "Sistema de Gestión Integral de la Secretaria de Salud de Moreno.",
  "repository": {
    "type": "git",
    "url": "https://github.com/PaZakwan/ssaludBack"
  },
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "nodemon server/server.js",
    "clean": "IF NOT EXIST dist MKDIR dist && rd /s /q dist && mkdir dist",
    "prebuild": "npm run clean",
    "build": "set NODE_OPTIONS=--max_old_space_size=2048 && ncc build server/server.js -o dist",
    "testB": "nodemon dist/index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "heroku-postbuild": "echo Skip build on Heroku",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "nodemonConfig": {
    "ignore": [
      "server/uploads/*"
    ]
  },
  "heroku-run-build-script": true,
  "author": "Paz Juan",
  "license": "AGPL-3.0-only",
  "dependencies": {
    "axios": "^1.15.2",
    "bcrypt": "^6.0.0",
    "connect-history-api-fallback": "^2.0.0",
    "cors": "^2.8.6",
    "csvtojson": "^2.0.14",
    "detect-file-encoding-and-language": "^2.4.0",
    "express": "^4.22.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.23.1",
    "mongoose-unique-validator": "^5.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-schedule": "^2.1.1",
    "nodemailer": "^8.0.7",
    "simple-xml-to-json": "^1.2.7",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.23.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.3.0",
    "globals": "^17.5.0"
  },
  "engines": {
    "node": "20.x - 24.x",
    "npm": "10.x - 11.x"
  }
}
